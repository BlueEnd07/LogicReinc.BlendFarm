<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="780"
        x:Class="LogicReinc.BlendFarm.Windows.ProjectWindow"
        Title="BlendFarm by LogicReinc"
        Background="{StaticResource BlendFarmWindowBrush}">
  <Window.Styles>
    <StyleInclude Source="avares://Avalonia.Themes.Default/Accents/BaseDark.xaml" />
  </Window.Styles>

  <Border Margin="24" Padding="24" Background="{StaticResource BlendFarmSurfaceBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" BorderThickness="1" CornerRadius="8">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
      <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
        <Image Source="/Images/header.png" Height="96" />
        <TextBlock TextAlignment="Center" Foreground="{StaticResource BlendFarmSubtleTextBrush}" Margin="0,8,0,0">Select your .blend project</TextBlock>
      </StackPanel>

      <Border Grid.Row="1" Background="{StaticResource BlendFarmPanelBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,12">
        <Grid ColumnDefinitions="*,140" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11">PROJECT FILE</TextBlock>
          <TextBox Grid.Row="1" Grid.Column="0" FontSize="11" x:Name="fileSelect" Margin="0,0,10,0" />
          <Button Grid.Row="1" Grid.Column="1" Padding="10,8" Command="{Binding ShowFileDialog}">Select File</Button>
        </Grid>
      </Border>

      <Border Grid.Row="2" Background="{StaticResource BlendFarmPanelBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,12">
        <Grid ColumnDefinitions="*,170" RowDefinitions="Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11">BLENDER VERSION</TextBlock>
          <ComboBox Grid.Row="1" Grid.Column="0" x:Name="versionSelect" Margin="0,0,10,0">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Grid.Row="1" Grid.Column="1" Padding="10,8" Command="{Binding ShowCustomWizard}">Add Custom Version</Button>
        </Grid>
      </Border>

      <Border Grid.Row="3" Background="{StaticResource BlendFarmPanelBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,12">
        <WrapPanel>
          <CheckBox x:Name="connectLocal" IsChecked="true" Margin="0,0,18,0">Connect Local</CheckBox>
          <CheckBox x:Name="importSettings" IsChecked="true" Margin="0,0,18,0">Import Settings</CheckBox>
          <CheckBox x:Name="useAssetSync" IsChecked="false" IsVisible="false">Use Asset Sync (Under Construction)</CheckBox>
        </WrapPanel>
      </Border>

      <Grid Grid.Row="4" RowDefinitions="Auto,*">
        <StackPanel x:Name="loadingUI" IsVisible="false" Margin="0,0,0,12">
          <ProgressBar x:Name="loading" IsIndeterminate="true" />
          <TextBlock x:Name="loadingText" Foreground="{StaticResource BlendFarmMutedTextBrush}" Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel x:Name="loadProjectUI">
          <TextBlock Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,0,8">RECENT PROJECTS</TextBlock>
          <ListBox x:Name="history" Background="{StaticResource BlendFarmPanelBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" Height="210" Padding="6" Margin="0,0,0,12">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource BlendFarmPanelSoftBrush}" BorderBrush="{StaticResource BlendFarmSoftBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                  <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontSize="15" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Date}" FontSize="10" Foreground="{StaticResource BlendFarmSubtleTextBrush}" Margin="12,3,0,0" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Path}" FontSize="10" Foreground="{StaticResource BlendFarmMutedTextBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Button Margin="0,0,0,12" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}" FontSize="18" Height="48" Background="{StaticResource BlendFarmAccentBrush}" Command="{Binding LoadProject}">Load Project</Button>

          <TextBlock Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,0,8">LAST ANNOUNCEMENT</TextBlock>
          <Button Background="{StaticResource BlendFarmPanelBrush}" Margin="0" BorderBrush="{StaticResource BlendFarmBorderBrush}" Height="48" Command="{Binding OpenLastAnnouncement}">
            <Grid ColumnDefinitions="Auto,*" Margin="10,0">
              <TextBlock Grid.Column="0" Text="{Binding LastAnnouncement.DateText}" Foreground="{StaticResource BlendFarmMutedTextBrush}" Margin="0,0,10,0" />
              <TextBlock Grid.Column="1" Text="{Binding LastAnnouncement.Name}" TextTrimming="CharacterEllipsis" />
            </Grid>
          </Button>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
