<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="950"
        x:Class="LogicReinc.BlendFarm.Windows.RenderWindow"
        xmlns:convs="clr-namespace:LogicReinc.BlendFarm.Converters;assembly=LogicReinc.BlendFarm"
        Title="BlendFarm by LogicReinc"
        Background="{StaticResource BlendFarmWindowBrush}">
  <Window.Styles>
    <StyleInclude Source="avares://Avalonia.Themes.Default/Accents/BaseDark.xaml" />
    <Style Selector="TabItem:selected">
      <Setter Property="Background" Value="{StaticResource BlendFarmAccentBrush}"/>
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="{StaticResource BlendFarmAccentBrush}"/>
    </Style>
    <Style Selector="ListBox.nodeCards ListBoxItem">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.nodeCards ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.nodeCards ListBoxItem:selected /template/ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.nodeCards ListBoxItem:pointerover /template/ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="*" Background="{StaticResource BlendFarmWindowBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="380" MinWidth="300" MaxWidth="680" />
      <ColumnDefinition Width="6" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="6" />
      <ColumnDefinition Width="460" />
    </Grid.ColumnDefinitions>
    <!--Left Panel-->
    <Border Grid.Row="0" Grid.Column="0"
            Background="{StaticResource BlendFarmSurfaceBrush}"
            BorderBrush="{StaticResource BlendFarmBorderBrush}"
            BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto" Margin="14">
        <StackPanel Grid.Row="0" Margin="0,8,0,16">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
            <Image Source="/Images/header.png" Width="34" Height="34" Margin="0,0,10,0" />
            <StackPanel VerticalAlignment="Center">
              <TextBlock Foreground="{StaticResource BlendFarmTextBrush}" FontSize="18" FontWeight="Bold">Logic Render Farm</TextBlock>
              <TextBlock Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11">LOCAL NETWORK</TextBlock>
            </StackPanel>
          </StackPanel>
          <Border Background="{StaticResource BlendFarmPanelBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
            <StackPanel>
              <TextBlock Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,0,5">NODE INSPECTOR</TextBlock>
              <TextBlock Foreground="{StaticResource BlendFarmTextBrush}" FontSize="20" FontWeight="Bold" Text="{Binding Nodes.Count}" />
              <TextBlock Foreground="{StaticResource BlendFarmMutedTextBrush}" FontSize="12">configured systems</TextBlock>
            </StackPanel>
          </Border>
          <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
            <Button Grid.Column="0" Padding="10,8" Margin="0,0,6,0" Command="{Binding ConnectAll}" Background="{StaticResource BlendFarmAccentBrush}" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}" Foreground="#FFFFFF">Connect All</Button>
            <Button Grid.Column="1" Padding="10,8" Margin="6,0,0,0" Command="{Binding SyncAll}" Background="{StaticResource BlendFarmButtonBrush}" BorderBrush="{StaticResource BlendFarmSoftBorderBrush}">Sync All</Button>
          </Grid>
        </StackPanel>

        <TabControl Grid.Row="1" Margin="0">
          <TabItem Header="Nodes">
            <ListBox Classes="nodeCards"
                     Items="{Binding Nodes}"
                     Background="Transparent"
                     BorderBrush="Transparent"
                     Padding="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Background="#202020"
                          BorderBrush="{StaticResource BlendFarmSoftBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="11"
                          Margin="0,0,0,10"
                          Opacity="{Binding DragOpacity}"
                          DragDrop.AllowDrop="True">
                    <Expander IsExpanded="{Binding IsInspectorExpanded}">
                      <Expander.Header>
                        <Grid ColumnDefinitions="14,*,Auto,Auto,Auto">
                          <Grid Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center">
                            <Ellipse Fill="#FF5066" IsVisible="{Binding !Connected}" />
                            <Ellipse Fill="#D6B94A">
                              <Ellipse.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                  <Binding Path="!IsSynced" />
                                  <Binding Path="Connected" />
                                </MultiBinding>
                              </Ellipse.IsVisible>
                            </Ellipse>
                            <Ellipse Fill="#12C979">
                              <Ellipse.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                  <Binding Path="IsSynced" />
                                  <Binding Path="Connected" />
                                </MultiBinding>
                              </Ellipse.IsVisible>
                            </Ellipse>
                          </Grid>
                          <StackPanel Grid.Column="1" Margin="8,0,6,0">
                            <TextBlock Text="{Binding NodeTitle}" Foreground="{StaticResource BlendFarmTextBrush}" FontWeight="Bold" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding NodeTitle}" />
                            <TextBlock Text="{Binding Address}" Foreground="{StaticResource BlendFarmMutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <Border Grid.Column="2" Background="#182D26" BorderBrush="#245C45" BorderThickness="1" CornerRadius="4" Padding="5,2" IsVisible="{Binding Connected}">
                            <TextBlock Text="{Binding StatusLabel}" Foreground="#12C979" FontSize="10" FontWeight="Bold" />
                          </Border>
                          <Border Grid.Column="2" Background="#321D28" BorderBrush="#6A2637" BorderThickness="1" CornerRadius="4" Padding="5,2" IsVisible="{Binding !Connected}">
                            <TextBlock Text="{Binding StatusLabel}" Foreground="#FF5066" FontSize="10" FontWeight="Bold" />
                          </Border>
                          <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                            <Button Background="Transparent" BorderThickness="0" Padding="3" Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ConfigureNode}" CommandParameter="{Binding .}" ToolTip.Tip="Node settings">
                              <Image Source="/Icons/gear.png" Height="15" Width="15" />
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="3" IsVisible="{Binding Connected}" Command="{Binding Disconnect}" ToolTip.Tip="Disconnect node">
                              <Image Source="/Icons/radioOn.png" Height="18" Width="18" />
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="3" IsEnabled="{Binding Activity, Converter={x:Static StringConverters.IsNullOrEmpty}}" IsVisible="{Binding !Connected}" Command="{Binding ConnectAndPrepare}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.Version.Name}" ToolTip.Tip="Connect node">
                              <Image Source="/Icons/radioOff.png" Height="18" Width="18" />
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="3" Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DeleteNode}" CommandParameter="{Binding .}" ToolTip.Tip="Delete node">
                              <Image Source="/Icons/delete.png" Height="17" Width="17" />
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="3" IsVisible="{Binding Connected}" Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=TerminalNode}" CommandParameter="{Binding .}" ToolTip.Tip="Open node console">
                              <Image Source="/Icons/terminal.png" Height="17" Width="17" />
                            </Button>
                          </StackPanel>
                          <Border Grid.Column="4" Background="#2A2A2A" BorderBrush="{StaticResource BlendFarmSoftBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center" PointerPressed="NodeInspectorPointerPressed" PointerMoved="NodeInspectorPointerMoved" ToolTip.Tip="Drag to reorder this node">
                            <TextBlock Text="::" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontWeight="Bold" />
                          </Border>
                        </Grid>
                      </Expander.Header>

                      <StackPanel>
                        <Border Height="1" Background="{StaticResource BlendFarmSoftBorderBrush}" Margin="0,10,0,9" />

                        <Grid ColumnDefinitions="72,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                          <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,8,5">Owner</TextBlock>
                          <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource BlendFarmTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,5" />

                          <TextBlock Grid.Row="1" Grid.Column="0" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,8,5">PC</TextBlock>
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ComputerName}" Foreground="{StaticResource BlendFarmTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,5" />

                          <TextBlock Grid.Row="2" Grid.Column="0" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,8,5">CPU</TextBlock>
                          <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CpuDisplay}" Foreground="{StaticResource BlendFarmTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,5" ToolTip.Tip="{Binding CpuDisplay}" />

                          <TextBlock Grid.Row="3" Grid.Column="0" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,8,5">GPU</TextBlock>
                          <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GpuDisplay}" Foreground="{StaticResource BlendFarmTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,5" ToolTip.Tip="{Binding GpuDisplay}" />

                          <TextBlock Grid.Row="4" Grid.Column="0" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,8,5">Memory</TextBlock>
                          <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MemoryDisplay}" Foreground="{StaticResource BlendFarmTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,5" />

                          <TextBlock Grid.Row="5" Grid.Column="0" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,8,5">Rendered</TextBlock>
                          <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding RenderedWorkDisplay}" Foreground="{StaticResource BlendFarmTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,5" ToolTip.Tip="{Binding RenderedWorkDisplay}" />

                          <TextBlock Grid.Row="6" Grid.Column="0" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,8,5">Avg</TextBlock>
                          <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding AverageRenderTimeDisplay}" Foreground="{StaticResource BlendFarmTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,0,5" ToolTip.Tip="Average time per completed animation frame on this node" />

                          <TextBlock Grid.Row="7" Grid.Column="0" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,8,0">OS</TextBlock>
                          <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding OSDisplay}" Foreground="{StaticResource BlendFarmTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding OSDisplay}" />
                        </Grid>
                      </StackPanel>
                    </Expander>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </TabItem>
          <TabItem ToolTip.Tip="Add node">
            <TabItem.Header>
              <Grid Width="18" Height="14" ToolTip.Tip="Add node">
                <Border Width="16" Height="10" BorderBrush="{StaticResource BlendFarmTextBrush}" BorderThickness="1.5" CornerRadius="1" HorizontalAlignment="Center" VerticalAlignment="Top" />
                <Border Width="8" Height="1.5" Background="{StaticResource BlendFarmTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                <Border Width="12" Height="1.5" Background="{StaticResource BlendFarmTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
              </Grid>
            </TabItem.Header>
            <Border Background="{StaticResource BlendFarmPanelBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,8,0,0">
              <StackPanel>
                <TextBox Margin="0,0,0,8" Watermark="Name" x:Name="inputClientName" Text="{Binding InputClientName}" />
                <TextBox Margin="0,0,0,8" Watermark="Address (eg. 192.168.1.53:1234)" x:Name="inputClientAddress" Text="{Binding InputClientAddress}" />
                <Grid ColumnDefinitions="90,*" Margin="0,0,0,8">
                  <TextBlock Grid.Column="0" Foreground="{StaticResource BlendFarmMutedTextBrush}" VerticalAlignment="Center">Render Type</TextBlock>
                  <ComboBox Grid.Column="1" Items="{Binding RenderTypes}" SelectedItem="{Binding NewNodeRenderType}" />
                </Grid>
                <Button Padding="10,9" Background="{StaticResource BlendFarmAccentBrush}" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}"
                    Command="{Binding AddNewNode}"
                    IsEnabled="{Binding ElementName=inputClientAddress, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">Connect Node</Button>
                <CheckBox Foreground="#D9DEF0" IsChecked="{Binding UseAutomaticPerformance}" Margin="0,12,0,0">
                  Use Automatic Performance
                </CheckBox>
                <CheckBox Foreground="#D9DEF0" IsChecked="{Binding UseSyncCompression}" Margin="0,6,0,0">
                  Use Sync Compression
                </CheckBox>
              </StackPanel>
            </Border>
          </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{StaticResource BlendFarmPanelBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
          <StackPanel>
            <TextBlock Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,0,10">RENDER FARM STATS</TextBlock>
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
              <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,10">
                <TextBlock Foreground="{StaticResource BlendFarmMutedTextBrush}" FontSize="12">Total Time Saved</TextBlock>
                <TextBlock x:Name="statsTotalSaved" FontSize="18" FontWeight="Bold">0:00</TextBlock>
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,10">
                <TextBlock Foreground="{StaticResource BlendFarmMutedTextBrush}" FontSize="12">Frames Today</TextBlock>
                <TextBlock x:Name="statsFramesToday" FontSize="18" FontWeight="Bold">0</TextBlock>
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Foreground="{StaticResource BlendFarmMutedTextBrush}" FontSize="12">Fastest Node</TextBlock>
                <TextBlock x:Name="statsFastestNode" FontSize="15" TextTrimming="CharacterEllipsis">--</TextBlock>
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Foreground="{StaticResource BlendFarmMutedTextBrush}" FontSize="12">Avg / Frame</TextBlock>
                <TextBlock x:Name="statsAverageFrame" FontSize="15">--</TextBlock>
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <GridSplitter Grid.Row="0" Grid.Column="1"
                  Width="6"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Background="{StaticResource BlendFarmSoftBorderBrush}"
                  ResizeDirection="Columns" />

    <Grid Grid.Row="0" Grid.Column="2" ColumnDefinitions="*">
      <Grid.RowDefinitions>
        <RowDefinition Height="50" />
        <RowDefinition Height="*" MinHeight="180" />
        <RowDefinition Height="6" />
        <RowDefinition Height="280" MinHeight="170" />
      </Grid.RowDefinitions>
      <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="*" ColumnDefinitions="*,35,50">

        
        <ListBox Items="{Binding Projects}" BorderBrush="Transparent" Padding="0,0,0,0" SelectionChanged="ProjectTabChanged" SelectedIndex="{Binding TabScrollIndex}" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Hidden">
          <ListBox.Styles>
            <Style Selector="ListBoxItem:selected /template/ContentPresenter">
              <Setter Property="Background" Value="{StaticResource BlendFarmAccentBrush}" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Button Content="{Binding Name}" Height="45" Padding="10,10,10,10" VerticalAlignment="Center" Command="{Binding SelectProject}" BorderBrush="Transparent" Background="Transparent"></Button>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!--
        <TabControl Items="{Binding Projects}" SelectionChanged="ProjectTabChanged" SelectedIndex="{Binding TabScrollIndex}">
          <TabControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Disabled" />
              </StackPanel>
            </ItemsPanelTemplate>
          </TabControl.ItemsPanel>
          <TabControl.ItemTemplate>
            <DataTemplate>
              <Button Content="{Binding Name}" Height="45" Padding="10,10,10,10" VerticalAlignment="Center" Command="{Binding SelectProject}" BorderBrush="Transparent" Background="Transparent"></Button>
            </DataTemplate>
          </TabControl.ItemTemplate>
          <TabControl.ContentTemplate>
            <DataTemplate>
              <StackPanel></StackPanel>
            </DataTemplate>
          </TabControl.ContentTemplate>
        </TabControl>-->
        


        <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="1*,1*">
          <Button Grid.Row="0" Background="Transparent" BorderBrush="Transparent" Command="{Binding ScrollLeft}" IsVisible="{Binding CanTabScrollLeft}">
            <Image Source="/Icons/menu-left-outline.png" />
          </Button>
          <Button Grid.Row="1" Background="Transparent" BorderBrush="Transparent" Command="{Binding ScrollRight}" IsVisible="{Binding CanTabScrollRight}">
            <Image Source="/Icons/menu-right-outline.png" />
          </Button>
        </Grid>
        <Button Grid.Row="0" Grid.Column="2" Background="{StaticResource BlendFarmAccentBrush}" FontSize="20" FontWeight="Bold" BorderBrush="Transparent" Command="{Binding OpenProjectDialog}">
          +
        </Button>
      </Grid>
      <Image x:Name="render"
            
            Source="{Binding CurrentProject.LastBitmap}"
            Grid.Row="1"
            Grid.Column="0"
            Stretch="Uniform">
      </Image>
      <ProgressBar
            IsVisible="{Binding CurrentProject.IsRendering}"
            x:Name="renderProgress"
            Grid.Column="0"
            Grid.Row="1"
            VerticalAlignment="Bottom"
            Height="5"></ProgressBar>
      <GridSplitter Grid.Row="2"
                    Grid.Column="0"
                    Height="6"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{StaticResource BlendFarmSoftBorderBrush}"
                    ResizeDirection="Rows" />
      <Border Grid.Row="3"
              Grid.Column="0"
              Background="{StaticResource BlendFarmSurfaceBrush}"
              BorderBrush="{StaticResource BlendFarmBorderBrush}"
              BorderThickness="0,1,0,0"
              Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="94" MinHeight="64" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="70" />
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,9">
            <TextBlock Grid.Column="0"
                       Foreground="{StaticResource BlendFarmSubtleTextBrush}"
                       FontSize="11"
                       FontWeight="Bold">RENDER PROGRESS</TextBlock>
            <TextBlock Grid.Column="1"
                       x:Name="renderProgressSummary"
                       Foreground="{StaticResource BlendFarmMutedTextBrush}"
                       FontSize="12">Idle</TextBlock>
          </Grid>
          <ListBox Grid.Row="1"
                   Classes="nodeCards"
                   Items="{Binding Nodes}"
                   Background="Transparent"
                   BorderBrush="Transparent"
                   Padding="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Width="250"
                        Height="82"
                        Background="{StaticResource BlendFarmPanelBrush}"
                        BorderBrush="{StaticResource BlendFarmBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="11"
                        Margin="0,0,10,0">
                  <Grid RowDefinitions="Auto,Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="12,*,Auto">
                      <Ellipse Grid.Column="0"
                               Width="9"
                               Height="9"
                               VerticalAlignment="Center"
                               Fill="#12C979"
                               IsVisible="{Binding Connected}" />
                      <Ellipse Grid.Column="0"
                               Width="9"
                               Height="9"
                               VerticalAlignment="Center"
                               Fill="#FF5066"
                               IsVisible="{Binding !Connected}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding NodeTitle}"
                                 Foreground="{StaticResource BlendFarmTextBrush}"
                                 FontWeight="Bold"
                                 TextTrimming="CharacterEllipsis"
                                 Margin="6,0,8,0"
                                 ToolTip.Tip="{Binding NodeTitle}" />
                      <TextBlock Grid.Column="2"
                                 Text="{Binding ActivityProgressDisplay}"
                                 Foreground="{StaticResource BlendFarmTextBrush}"
                                 FontWeight="Bold"
                                 FontSize="12" />
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding ActivityDisplay}"
                               Foreground="{StaticResource BlendFarmMutedTextBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="18,7,0,0"
                               ToolTip.Tip="{Binding ActivityDisplay}" />
                    <ProgressBar Grid.Row="2"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ActivityProgressValue}"
                                 Height="8"
                                 VerticalAlignment="Bottom" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <GridSplitter Grid.Row="2"
                        Height="6"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{StaticResource BlendFarmSoftBorderBrush}"
                        ResizeDirection="Rows" />
          <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,8,0,8">
            <TextBlock Grid.Column="0"
                       Foreground="{StaticResource BlendFarmSubtleTextBrush}"
                       FontSize="11"
                       FontWeight="Bold">ACTIVITY LOG</TextBlock>
            <Button Grid.Column="1"
                    Padding="8,3"
                    FontSize="11"
                    Background="Transparent"
                    BorderBrush="{StaticResource BlendFarmSoftBorderBrush}"
                    Command="{Binding ClearActivityLog}">Clear Log</Button>
          </Grid>
          <Border Grid.Row="4"
                  Background="{StaticResource BlendFarmPanelBrush}"
                  BorderBrush="{StaticResource BlendFarmBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="8">
            <ListBox x:Name="activityLogList"
                     Items="{Binding ActivityLog}"
                     Background="Transparent"
                     BorderBrush="Transparent"
                     Padding="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="62,*" Margin="0,0,0,5">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Time}"
                               Foreground="{StaticResource BlendFarmMutedTextBrush}"
                               FontFamily="Consolas"
                               FontSize="12" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Message}"
                               Foreground="{StaticResource BlendFarmTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <GridSplitter Grid.Row="0" Grid.Column="3"
                  Width="6"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Background="{StaticResource BlendFarmSoftBorderBrush}"
                  ResizeDirection="Columns" />

    <!--Right Panel-->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Grid.Row="0" Grid.Column="4"
            Background="{StaticResource BlendFarmSurfaceBrush}">
      <StackPanel Orientation="Vertical" Margin="14">
        <DockPanel>
          <StackPanel Margin="0,0,0,18" DockPanel.Dock="Top">
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
              <StackPanel Grid.Column="0">
                <TextBlock Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11">LOCAL NETWORK</TextBlock>
                <TextBlock Foreground="{StaticResource BlendFarmTextBrush}" FontSize="20" FontWeight="Bold">Render Control</TextBlock>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Padding="10,6" BorderBrush="{StaticResource BlendFarmSoftBorderBrush}" Background="{StaticResource BlendFarmButtonBrush}" Command="{Binding Help}">
                  Help
                </Button>
              </StackPanel>
            </Grid>

            <Border Background="{StaticResource BlendFarmPanelBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,10">
              <StackPanel>
                <Grid ColumnDefinitions="70,*" Margin="0,0,0,6">
                  <TextBlock Grid.Column="0" Foreground="#A6A6A6" FontSize="12">Version</TextBlock>
                  <TextBlock Grid.Column="1" Foreground="#F4F6FF" Text="{Binding Version.Name}"></TextBlock>
                </Grid>
                <Grid ColumnDefinitions="70,*">
                  <TextBlock Grid.Column="0" Foreground="#A6A6A6" FontSize="12">File</TextBlock>
                  <TextBlock Grid.Column="1" Foreground="#D9DEF0" TextTrimming="CharacterEllipsis" Text="{Binding CurrentProject.BlendFileDisplay}" ToolTip.Tip="{Binding CurrentProject.BlendFile}"></TextBlock>
                </Grid>
              </StackPanel>
            </Border>

            <StackPanel Margin="20,20,20,5" Orientation="Horizontal" IsVisible="False">
              <Button Padding="0" BorderThickness="0" Background="{StaticResource BlendFarmButtonBrush}" Command="{Binding Github}">
                <Image Source="/Icons/github.png" Width="150" Height="25"></Image>
              </Button>
              <Button Padding="0" BorderThickness="0" Command="{Binding Patreon}">
                <Image Source="/Icons/patreon.png" Width="150"></Image>
              </Button>
            </StackPanel>
            <StackPanel Margin="20,0,20,10" Orientation="Vertical" IsVisible="False">
              <Button Height="25" Padding="0,5,0,5" BorderThickness="0" Background="{StaticResource BlendFarmButtonBrush}" Command="{Binding Help}">
                Help!
              </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" IsVisible="False">
              <TextBlock Width="60" Margin="0,0,15,0" TextAlignment="Right">Version:</TextBlock>
              <TextBlock Width="240"  Text="{Binding Version.Name}"></TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" IsVisible="False">
              <TextBlock Width="60" Margin="0,0,15,0" TextAlignment="Right">File:</TextBlock>
              <TextBlock Width="240"  Text="{Binding CurrentProject.BlendFile}"></TextBlock>
            </StackPanel>

            <Canvas Height="0" Margin="0,10,0,0" IsVisible="False">
              <StackPanel Orientation="Horizontal" Canvas.Right="30" Canvas.Top="4">
                <TextBlock Margin="0,7,10,0">
                  Use Queue
                </TextBlock>
                <ToggleSwitch Checked="CheckUseQueue" Unchecked="CheckUseQueue"></ToggleSwitch>
              </StackPanel>
            </Canvas>

            <TabControl Margin="0,0,0,0" SelectedIndex="0">
              <TabItem Header="Render">
                <!--BEGIN RENDER-->
                <StackPanel Orientation="Vertical">
                  <Border Background="{StaticResource BlendFarmPanelBrush}" BorderBrush="{StaticResource BlendFarmBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="0" Margin="0,0,0,10">
                  <StackPanel DockPanel.Dock="Bottom">
                    <TabControl SelectedIndex="0" Margin="0,0,0,0">
                      <TabItem Header="Render Settings" Margin="10,0,0,0">
                        <StackPanel Background="{StaticResource BlendFarmPanelBrush}">
                          <StackPanel Margin="14,18,14,10">
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,8">
                              <Grid Grid.Column="0" ColumnDefinitions="70,*" Margin="0,0,6,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8">Width</TextBlock>
                                <NumericUpDown Grid.Column="1" Value="{Binding CurrentProject.RenderWidth}" />
                              </Grid>
                              <Grid Grid.Column="1" ColumnDefinitions="70,*" Margin="6,0,0,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8">Height</TextBlock>
                                <NumericUpDown Grid.Column="1" Value="{Binding CurrentProject.RenderHeight}" />
                              </Grid>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,8">
                              <Grid Grid.Column="0" ColumnDefinitions="70,*" Margin="0,0,6,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8">Scale %</TextBlock>
                                <NumericUpDown Grid.Column="1" Minimum="1" Maximum="400" Increment="1" Value="{Binding CurrentProject.RenderScale}" />
                              </Grid>
                              <Grid Grid.Column="1" ColumnDefinitions="70,*" Margin="6,0,0,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8">Samples</TextBlock>
                                <NumericUpDown Grid.Column="1" Value="{Binding CurrentProject.Samples}" />
                              </Grid>
                            </Grid>
                            <Grid ColumnDefinitions="70,*" Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8" ToolTip.Tip="Denoiser to use, Inherit means the one selected in Blendfile.">Denoiser</TextBlock>
                              <ComboBox Grid.Column="1" SelectedIndex="0" Items="{Binding DenoiserOptions}" SelectedItem="{Binding CurrentProject.Denoiser}"></ComboBox>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,8">
                              <Grid Grid.Column="0" ColumnDefinitions="70,*" Margin="0,0,6,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8">Scene</TextBlock>
                                <ComboBox Grid.Column="1" x:Name="sceneComboBox" Items="{Binding CurrentProject.ScenesAvailable}" />
                              </Grid>
                              <Grid Grid.Column="1" ColumnDefinitions="70,*" Margin="6,0,0,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8">Camera</TextBlock>
                                <ComboBox Grid.Column="1" x:Name="cameraComboBox" Items="{Binding CurrentProject.CamerasAvailable}" />
                              </Grid>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,8">
                              <Grid Grid.Column="0" ColumnDefinitions="88,*" Margin="0,0,6,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8">File Format</TextBlock>
                                <TextBox Grid.Column="1" x:Name="inputAnimationFileFormat" Text="{Binding CurrentProject.AnimationFileFormat}" />
                              </Grid>
                              <Grid Grid.Column="1" ColumnDefinitions="70,*" Margin="6,0,0,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8" ToolTip.Tip="File format Blender should render in">Output</TextBlock>
                                <ComboBox Grid.Column="1" x:Name="selectOutputType" Items="{Binding ImageFormats}" SelectedItem="{Binding CurrentProject.RenderFormat}" FontSize="15" />
                              </Grid>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" Margin="0,0,0,8">
                              <Grid Grid.Column="0" ColumnDefinitions="88,*" Margin="0,0,6,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8" ToolTip.Tip="Frame to start at">Frame Start</TextBlock>
                                <NumericUpDown Grid.Column="1" Value="{Binding CurrentProject.FrameStart}" />
                              </Grid>
                              <Grid Grid.Column="1" ColumnDefinitions="70,*" Margin="6,0,0,0">
                                <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,8,8,8" ToolTip.Tip="Frame to end at">Frame End</TextBlock>
                                <NumericUpDown Grid.Column="1" Value="{Binding CurrentProject.FrameEnd}" />
                              </Grid>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,5">
                              <StackPanel Grid.Column="0">
                                <Grid ColumnDefinitions="140,*">
                                  <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,4,8,4">Last Render Time</TextBlock>
                                  <TextBlock Grid.Column="1" x:Name="lastRenderTime" Foreground="#F4F6FF" Margin="0,4,8,4">...</TextBlock>
                                </Grid>
                                <Grid ColumnDefinitions="140,*">
                                  <TextBlock Grid.Column="0" Foreground="#B8B8B8" TextAlignment="Left" Margin="0,4,8,4">Estimated Remaining</TextBlock>
                                  <TextBlock Grid.Column="1" x:Name="estimatedRenderTime" Foreground="#F4F6FF" Margin="0,4,8,4">...</TextBlock>
                                </Grid>
                              </StackPanel>
                              <CheckBox Grid.Column="1" Foreground="#D9DEF0" VerticalAlignment="Center" IsChecked="{Binding CurrentProject.UseWorkaround}" ToolTip.Tip="Workaround for a Blender bug, once fixed, it may cause odd tile order, then disable this">Workaround</CheckBox>
                            </Grid>
                          </StackPanel>
							<Grid ColumnDefinitions="*,*" Margin="14,0,14,6">
								<Button Grid.Column="0" Margin="0,0,6,0" Padding="10,8" Command="{Binding ImportSettings}" Background="{StaticResource BlendFarmButtonBrush}" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}">
									Import Settings
								</Button>
								<Button Grid.Column="1" Margin="6,0,0,0" Padding="10,8" Command="{Binding ImportMeta}" Background="{StaticResource BlendFarmButtonBrush}" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}">
									Import Scenes
								</Button>
							</Grid>
                          <Grid ColumnDefinitions="*,*" Margin="14,3,14,5">
                            <Button Grid.Column="0" Margin="0,0,6,0" Padding="10,9" IsVisible="{Binding !CurrentProject.IsRendering}" Command="{Binding Render}" Background="{StaticResource BlendFarmAccentBrush}" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}">
                              Render Now
                            </Button>
                            <Button Grid.Column="1" Margin="6,0,0,0" Padding="10,9" IsVisible="{Binding !CurrentProject.IsRendering}" Command="{Binding RenderAnimation}" Background="{StaticResource BlendFarmAccentBrush}" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}">
                              Render Animation
                            </Button>
                            <Button Grid.ColumnSpan="2" Padding="10,9" IsVisible="{Binding CurrentProject.IsRendering}" Command="{Binding CancelRender}" Background="#B91C1C" BorderBrush="#EF4444">
                              Cancel
                            </Button>
                          </Grid>
                          <Grid ColumnDefinitions="*,*" Margin="14,0,14,5">
                            <Button Grid.Column="0" Margin="0,0,6,0" Padding="10,9" Command="{Binding AddToQueueNew}" Background="{StaticResource BlendFarmButtonBrush}" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}">
                              Add to Queue
                            </Button>
                            <Button Grid.Column="1" Margin="6,0,0,0" Padding="10,9" Command="{Binding AddAnimationToQueueNew}" Background="{StaticResource BlendFarmButtonBrush}" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}">
                              Add Queue Animation
                            </Button>
                          </Grid>
                          <Border x:Name="animationProgressPanel" IsVisible="False" Background="#2A2A2A" BorderBrush="#505050" BorderThickness="1" CornerRadius="4" Margin="14,4,14,5" Padding="12">
                            <StackPanel>
                              <TextBlock Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Margin="0,0,0,8">ANIMATION PROGRESS</TextBlock>
                              <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{StaticResource BlendFarmMutedTextBrush}" Margin="0,2,8,2">Frames Rendered</TextBlock>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="animationFramesRendered" Margin="0,2,0,2">--</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="0" Foreground="{StaticResource BlendFarmMutedTextBrush}" Margin="0,2,8,2">Current Frame</TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="animationCurrentFrame" Margin="0,2,0,2">--</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="0" Foreground="{StaticResource BlendFarmMutedTextBrush}" Margin="0,2,8,2">Estimated Remaining</TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="animationEstimatedRemaining" Margin="0,2,0,2">--</TextBlock>
                              </Grid>
                              <ProgressBar x:Name="animationTimelineProgress" Minimum="0" Maximum="100" Height="8" Margin="0,10,0,8" />
                              <TextBlock x:Name="animationTimeline" FontFamily="Consolas" Foreground="{StaticResource BlendFarmMutedTextBrush}" TextAlignment="Center">--</TextBlock>
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </TabItem>
                      <TabItem Header="Live Render" IsEnabled="{Binding !IsQueueing}">
                        <StackPanel Margin="10,20,10,10" Background="#1F1F1F">
                          <TextBlock TextWrapping="Wrap" Margin="10" Width="300">
                            Live render will re-render the file whenever it changes (with settings from Image tab), it can only be used with a single project open and no queue.
                          </TextBlock>
                          <Button Margin="10,10,10,5" IsVisible="{Binding !IsLiveChanging}" Command="{Binding StartLiveRender}" Background="{StaticResource BlendFarmAccentBrush}" BorderBrush="{StaticResource BlendFarmAccentBorderBrush}">
                            Start Live Render
                          </Button>
                          <Button Margin="10,0,10,5" IsVisible="{Binding IsLiveChanging}" Command="{Binding StopLiveRender}" Background="#9B2C2C" BorderBrush="#C44A4A">
                            Stop Live Render
                          </Button>
                        </StackPanel>
                      </TabItem>
                      <TabItem Header="System">
                        <StackPanel Orientation="Vertical">
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Width="90" TextAlignment="Right" Margin="10" ToolTip.Tip="The strategy to render the image. Splitted is fastest, but less real-time preview. SplitChunked has real-time tiles updating but has some overhead. Chunked is slow, but allows rendernodes to consume work as available.">
                              Render Strategy
                            </TextBlock>
                            <ComboBox SelectedIndex="0" Width="105" x:Name="selectStrategy" />
                            <TextBlock Width="30" TextAlignment="Right" Margin="10" ToolTip.Tip="Order to render tiles, only relevant for Chunked and SplitChunked">Order</TextBlock>
                            <ComboBox SelectedIndex="0" Width="80" x:Name="selectOrder" />
                          </StackPanel>
                          <StackPanel Orientation="Horizontal">
                            <TextBlock Width="90" TextAlignment="Right" Margin="10" ToolTip.Tip="Chunksize for Chunked and SplitChunked, may be modified in certain scenarios">ChunkSize</TextBlock>
                            <NumericUpDown Width="80" Value="{Binding CurrentProject.ChunkSize}" />

                            <TextBlock Width="55" TextAlignment="Right" Margin="10" ToolTip.Tip="Which engine to use. Optix will adhere to CUDA settings. Otherwise CPU is used.">
                              Engine
                            </TextBlock>
                            <ComboBox x:Name="selectRenderType" Margin="0,0,0,0" Items="{Binding EngineOptions}" SelectedItem="{Binding CurrentProject.Engine}" FontSize="15"></ComboBox>
                            <!--<CheckBox IsChecked="{Binding CurrentProject.UseEevee}" /> -->
                          </StackPanel>
                          <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Width="110" TextAlignment="Right" Margin="10" ToolTip.Tip="Use a network location instead of transfering over TCP (Allows for shared resources)">
                                Use Networked Path
                              </TextBlock>
                              <CheckBox IsChecked="{Binding CurrentProject.UseNetworkedPath}" />
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Background="#1A1A1A"  IsVisible="{Binding CurrentProject.UseNetworkedPath}">
                              <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Width="90" TextAlignment="Right" Margin="10">Windows Path</TextBlock>
                                <TextBox Width="220" Text="{Binding CurrentProject.NetworkPathWindows}"></TextBox>
                                <Button IsVisible="{Binding IsWindows}" Command="{Binding SelectNetworkWindowsPath}">...</Button>
                              </StackPanel>
                              <StackPanel Orientation="Horizontal" Margin="0,00,0,0">
                                <TextBlock Width="90" TextAlignment="Right" Margin="10">Linux Path</TextBlock>
                                <TextBox Width="220" Text="{Binding CurrentProject.NetworkPathLinux}"></TextBox>
                                <Button IsVisible="{Binding IsLinux}" Command="{Binding SelectNetworkLinuxPath}">...</Button>
                              </StackPanel>
                              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Width="90" TextAlignment="Right" Margin="10">MacOS Path</TextBlock>
                                <TextBox Width="220" Text="{Binding CurrentProject.NetworkPathMacOS}"></TextBox>
                                <Button IsVisible="{Binding IsMacOS}" Command="{Binding SelectNetworkMacOSPath}">...</Button>
                              </StackPanel>
                            </StackPanel>
                          </StackPanel>
                        </StackPanel>
                      </TabItem>
                    </TabControl>
                  </StackPanel>
                  </Border>
                
                </StackPanel>
                <!--END RENDER-->
              </TabItem>
              <TabItem Header="{Binding QueueName}">
                <!--BEGIN QUEUE-->
                <ListBox Items="{Binding Queue}" Background="Transparent" BorderBrush="{StaticResource BlendFarmBorderBrush}" Padding="6" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#202020" BorderBrush="{StaticResource BlendFarmSoftBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                          <StackPanel Grid.Row="0" Grid.Column="0" MinWidth="0">
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource BlendFarmTextBrush}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SettingsSummary}" Foreground="{StaticResource BlendFarmMutedTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,3,8,0" />
                            <TextBlock Text="{Binding State}" Foreground="#AAAAAA" FontSize="12" Margin="0,3,0,0" />
                          </StackPanel>
                          <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Padding="8,5" Margin="0,0,6,0" IsVisible="{Binding Completed}" Command="{Binding OpenQueueItem}" Background="Transparent" BorderBrush="{StaticResource BlendFarmSoftBorderBrush}" Foreground="#00FF33">Open</Button>
                            <Button Padding="8,5" Margin="0,0,6,0" IsVisible="{Binding IsCancelable}" Command="{Binding CancelQueueItem}" Background="Transparent" BorderBrush="{StaticResource BlendFarmSoftBorderBrush}" Foreground="#FF5555">Cancel</Button>
                            <Button Padding="7,5" Width="34" IsVisible="{Binding IsDeletable}" Command="{Binding DeleteQueueItem}" Background="Transparent" BorderBrush="{StaticResource BlendFarmSoftBorderBrush}" ToolTip.Tip="Delete from queue">
                              <Image Source="/Icons/delete.png" Height="15" Width="15" />
                            </Button>
                          </StackPanel>
                          <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,*" Margin="0,8,0,0">
                            <TextBlock Grid.Column="0" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Text="{Binding SaveToDisplay}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding SaveTo}" />
                            <TextBlock Grid.Column="1" Foreground="{StaticResource BlendFarmSubtleTextBrush}" FontSize="11" Text="{Binding RenderKind}" HorizontalAlignment="Right" />
                          </Grid>
                          <ProgressBar Grid.Row="2" Grid.ColumnSpan="2" IsVisible="{Binding IsRendering}" Value="{Binding ProgressPercentage}" Height="4" Margin="0,8,0,0" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <!--END QUEUE-->
              </TabItem>
            </TabControl>
          </StackPanel>
          
        </DockPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>

</Window>
